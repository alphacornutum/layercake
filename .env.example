# macOS: AppleScript application name, e.g. "Adobe After Effects 2025"
AE_APP_NAME=

# macOS: path to After Effects .app (validation / derive app name)
# AE_EXECUTABLE=/Applications/Adobe After Effects 2025/Adobe After Effects 2025.app
#
# Windows: required path to AfterFX.exe
# AE_EXECUTABLE=C:\Program Files\Adobe\Adobe After Effects 2026\Support Files\AfterFX.exe
AE_EXECUTABLE=

# ExtendScript evaluation timeout (milliseconds)
AE_SCRIPT_TIMEOUT_MS=60000

# Max UTF-8 bytes for ae_get_layer / ae_get_source success JSON (default 524288 = 512 KiB)
AE_INSPECT_MAX_BYTES=524288

# Optional override for scripting guide markdown corpus
# Default: vendor/after-effects-scripting-guide/docs
AE_DOCS_PATH=

# Absolute directory for backups and LayerCake-generated artifacts
# Default: OS temp dir layercake-artifacts-<pid>
# AE_ARTIFACT_DIR=/tmp/layercake-artifacts
AE_ARTIFACT_DIR=
