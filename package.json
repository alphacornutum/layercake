{
  "name": "layercake",
  "version": "0.1.0",
  "description": "LayerCake — MCP server for local Adobe After Effects: open projects, run ExtendScript, and search scripting docs",
  "keywords": [
    "adobe",
    "after-effects",
    "extendscript",
    "layercake",
    "mcp",
    "model-context-protocol"
  ],
  "homepage": "https://github.com/alphacornutum/layercake#readme",
  "bugs": {
    "url": "https://github.com/alphacornutum/layercake/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alphacornutum/layercake.git"
  },
  "bin": {
    "layercake": "./dist/index.js"
  },
  "files": [
    "dist",
    "skills"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:ae": "vitest run --config vitest.ae.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "docs:fetch": "node scripts/fetch-docs.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "extendscript-json": "^0.1.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "tsx": "^4.23.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20"
  }
}
