{
  "name": "layercake",
  "version": "0.1.0",
  "description": "LayerCake — MCP server for local Adobe After Effects: template-first, state-aware automation",
  "keywords": [
    "adobe",
    "after-effects",
    "extendscript",
    "layercake",
    "mcp",
    "model-context-protocol"
  ],
  "homepage": "https://github.com/alphacornutum/layercake#readme",
  "bugs": {
    "url": "https://github.com/alphacornutum/layercake/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/alphacornutum/layercake.git"
  },
  "bin": {
    "layercake": "./dist/index.js"
  },
  "files": [
    "dist",
    "skills",
    "vendor/after-effects-scripting-guide"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "npm run build:ae-scripts && tsx src/index.ts",
    "build:ae-scripts": "node scripts/build-ae-scripts.mjs",
    "build": "npm run build:ae-scripts && tsc -p tsconfig.build.json",
    "start": "node dist/index.js",
    "test": "npm run build:ae-scripts && vitest run",
    "test:ae": "npm run build:ae-scripts && vitest run --config vitest.ae.config.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p tsconfig.ae.json --noEmit",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "fmt": "oxfmt .",
    "fmt:check": "oxfmt --check .",
    "docs:fetch": "node scripts/fetch-docs.mjs",
    "docs:allowlist": "node scripts/generate-first-party-effect-allowlist.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "extendscript-json": "^0.1.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.3.0",
    "@types/node": "^24.0.0",
    "acorn": "^8.17.0",
    "eslint-scope": "^8.4.0",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "rollup": "^4.62.2",
    "tslib": "^2.8.1",
    "tsx": "^4.23.1",
    "types-for-adobe": "^7.2.5",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20"
  }
}
