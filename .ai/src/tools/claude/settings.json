{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(node *)",
      "Bash(tsx *)",
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git branch *)",
      "Bash(agentsync *)",
      "Bash(openspec *)",
      "Bash(ls *)",
      "Bash(cat package.json)",
      "Read",
      "Write",
      "Edit",
      "Glob",
      "Grep",
      "mcp__layercake__ae_host_status",
      "mcp__layercake__ae_open_project",
      "mcp__layercake__ae_eval_script",
      "mcp__layercake__ae_list_comps",
      "mcp__layercake__ae_list_sources",
      "mcp__layercake__ae_list_folders",
      "mcp__layercake__ae_docs_search",
      "mcp__layercake__ae_docs_get",
      "mcp__code-review-graph__get_minimal_context_tool",
      "mcp__code-review-graph__list_graph_stats_tool",
      "mcp__code-review-graph__build_or_update_graph_tool",
      "mcp__code-review-graph__detect_changes_tool",
      "mcp__code-review-graph__get_review_context_tool",
      "mcp__code-review-graph__get_impact_radius_tool",
      "mcp__code-review-graph__get_affected_flows_tool",
      "mcp__code-review-graph__query_graph_tool",
      "mcp__code-review-graph__semantic_search_nodes_tool"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(curl * | bash *)",
      "Bash(wget * | sh *)",
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/.env)",
      "Read(**/credentials.json)",
      "Write(.env)",
      "Write(.env.*)"
    ]
  }
}
